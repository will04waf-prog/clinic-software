# ============================================================
# Tarhunna — Environment Variables
# ============================================================
# Copy this file to .env.local for local dev and fill in values.
# Production values are set in the Vercel project: Settings → Environment Variables.
# Never commit .env.local — it's gitignored.

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tarhunna.net

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Per-tier Price IDs. All 6 must be set — billing throws on first call to
# priceIdForTier() / tierFromPriceId() if any are missing. Create these in
# the Stripe Dashboard: Products → New, then add a recurring monthly and
# annual price for each of the three tiers.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_ANNUAL=

# ── Resend (transactional email) ────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Twilio (SMS) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Cron auth ───────────────────────────────────────────────
# Shared secret in the Authorization header from Vercel cron requests.
CRON_SECRET=
