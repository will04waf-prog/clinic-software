# ============================================================
# Tarhunna — Environment Variables
# ============================================================
# Copy this file to .env.local for local dev and fill in values.
# Production values are set in the Vercel project: Settings → Environment Variables.
# Never commit .env.local — it's gitignored.

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tarhunna.net

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Per-tier Price IDs. All 6 must be set — billing throws on first call to
# priceIdForTier() / tierFromPriceId() if any are missing. Create these in
# the Stripe Dashboard: Products → New, then add a recurring monthly and
# annual price for each of the three tiers.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_ANNUAL=

# ── Resend (transactional email) ────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Twilio (SMS) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── AI (Anthropic) ──────────────────────────────────────────
# Server-side only. Used by /api/leads/[id]/draft-message to generate
# follow-up message drafts. Never exposed to the client.
ANTHROPIC_API_KEY=

# ── Cron auth ───────────────────────────────────────────────
# Shared secret in the Authorization header from Vercel cron requests.
CRON_SECRET=

# ── Booking manage tokens (Phase 4 W5) ──────────────────────
# HMAC secret used to sign /manage/[token] links sent to patients in
# their booking-confirmation SMS. Must be ≥16 chars. Rotate to break
# all in-flight links (treat rotation as the response to compromise).
MANAGE_TOKEN_SECRET=

# ── Vapi (Phase 5 W1 — Voice Phone Twin) ────────────────────
# Private API key for managing assistants / tools / phone numbers
# via the Vapi REST API. Created at vapi.ai → Dashboard → API Keys.
VAPI_API_KEY=
# Webhook signing secret. Created in Vapi → Server URL settings.
# Vapi sends this in the x-vapi-secret header on every tool-call
# webhook so we can verify the request is genuinely from Vapi.
# If unset, /api/voice/tool/* logs a warning and skips verification
# (acceptable during development; lock down before real patient
# calls route through the agent).
VAPI_WEBHOOK_SECRET=

# ── Multi-clinic phone infrastructure (M1–M7) ───────────────
# These env vars are consumed by the per-org phone-number
# provisioning queue (M5), the Twilio A2P 10DLC poller (M4),
# the SMS A2P gate (M1), and the metered-billing reporter (M7).
#
# All of them are OPTIONAL in dev. In production they should be
# set in Vercel → Settings → Environment Variables before flipping
# the corresponding feature flags. See docs/MULTI_CLINIC_RUNBOOK.md
# for the full operator walkthrough.

# Stripe metered Price IDs. Presence of each gates the matching
# kind in /api/cron/report-usage. While unset, usage_events rows
# are still INSERTED (audit trail) but never reported to Stripe.
# Spec aliases (preferred for new docs): STRIPE_PRICE_PHONE_NUMBER_RENT,
# STRIPE_PRICE_VOICE_MINUTES_OVERAGE, STRIPE_PRICE_SMS_OVERAGE.
# The actual env-var names the code reads today are:
STRIPE_PHONE_NUMBER_PRICE_ID=
STRIPE_VOICE_OVERAGE_PRICE_ID=
STRIPE_SMS_OVERAGE_PRICE_ID=
# Optional re-aliases — define these in Vercel matching the names
# the runbook uses, so future renames in code can flip without
# operator action.
STRIPE_PRICE_PHONE_NUMBER_RENT=
STRIPE_PRICE_VOICE_MINUTES_OVERAGE=
STRIPE_PRICE_SMS_OVERAGE=

# A2P SMS block — feature flag. When 'true', sendSMS() in
# src/lib/twilio.ts blocks outbound SMS for organizations whose
# a2p_status is not 'approved'. Defaults off so trial clinics
# can still send transactional messages while their brand is
# being vetted. The actual env-var name the code reads is
# A2P_REQUIRED; A2P_SMS_BLOCK_ENABLED is the doc alias.
A2P_REQUIRED=false
A2P_SMS_BLOCK_ENABLED=false

# Metered-usage cron feature flag. The cron actually reports to
# Stripe when this is 'true' AND the matching STRIPE_*_PRICE_ID
# is set. While 'false', usage rows are still stamped locally
# so dashboards can render historical totals.
METERED_USAGE_ENABLED=false

# Provisioning queue retry budget. Max attempts before a row in
# provisioning_jobs flips to status='failed' and an operator must
# manually intervene via /admin/numbers → "Re-trigger". Default 5
# is baked into src/lib/provisioning/queue.ts; setting this var
# is reserved for ops emergencies.
PROVISIONING_RETRY_MAX=5

# Default ISO-3166-1 alpha-2 country code for AvailablePhoneNumbers
# search in src/lib/telephony/twilio-numbers.ts. Today the search
# hardcodes 'US'; this env var is reserved for the multi-country
# expansion. Set to 'CA' for a Canada-first deploy.
TWILIO_DEFAULT_COUNTRY=US

# Twilio TrustHub policy SID overrides. Twilio publishes stable
# policy SIDs for the Secondary CustomerProfile and the A2P
# TrustProduct; src/lib/telephony/a2p.ts hardcodes them today.
# Set these only if Twilio publishes new SIDs that supersede the
# baked-in ones (rare — they have not changed since 2023).
TWILIO_TRUSTHUB_SECONDARY_PROFILE_POLICY_SID=RNdfbf3fae0e1107f8aded0e7cead80bf5
TWILIO_TRUSTHUB_A2P_POLICY_SID=RNb0d4771c2c98518d916a3d4cd70a8f8b
